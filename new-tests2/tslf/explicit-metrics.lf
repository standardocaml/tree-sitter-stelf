	%pi (can-mcn-deq (cn-deq/cn/pair D1 D2) (mcn-deq/cn/pair D1' D2'))
	%<- (can-mcn-deq D1 D1')
	%<- (can-mcn-deq D2 D2') %.
%term _ 
	%pi (can-mcn-deq (cn-deq/tp/cross D1 D2) (mcn-deq/tp/cross D1' D2'))
	%<- (can-mcn-deq D1 D1')
