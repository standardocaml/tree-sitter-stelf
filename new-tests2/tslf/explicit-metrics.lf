	%pi (can-mcn-deq (cn-deq/cn/pj2 D1) (mcn-deq/cn/pj2 D1'))
	%<- (can-mcn-deq D1 D1') %.
%term _ 
	%pi (can-mcn-deq (cn-deq/kd/unit D1 D2) (mcn-deq/kd/unit D1' D2'))
	%<- (can-mofkd D1 D1')
	%<- (can-mofkd D2 D2') %.
%term _ 
	%pi (can-mcn-deq (cn-deq/trans D1 D2) (mcn-deq/trans D1' D2'))
	%<- (can-mcn-deq D1 D1')
	%<- (can-mcn-deq D2 D2') %.
