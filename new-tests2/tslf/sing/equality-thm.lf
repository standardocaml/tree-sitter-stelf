%%%%%  Extra Worlds  %%%%%
%worlds () (constant) %.
%worlds (evar) (etp) (eterm) %.
%%%%%  Equalities  %%%%%
%sort atom-eq {_ atom} {_ atom} %.
%term atom-eq/i atom-eq R R %.
%sort constant-eq {_ constant} {_ constant} %.
%term constant-eq/i constant-eq C C %.
%sort ctp-eq {_ ctp} {_ ctp} %.
%term ctp-eq/i ctp-eq A A %.
%sort ctx-eq {_ ctx} {_ ctx} %.
%term ctx-eq/i ctx-eq G G %.
%sort eterm-eq {_ eterm} {_ eterm} %.
%term eterm-eq/i eterm-eq M M %.
%sort etp-eq {_ etp} {_ etp} %.
%term etp-eq/i etp-eq A A %.
%sort sctx-eq {_ sctx} {_ sctx} %.
%term sctx-eq/i sctx-eq G G %.
%sort stp-eq {_ stp} {_ stp} %.
%term stp-eq/i stp-eq T T %.
%sort term-eq {_ term} {_ term} %.
%term term-eq/i term-eq M M %.
%sort tp-eq {_ tp} {_ tp} %.
%term tp-eq/i tp-eq T T %.
%%%%%  A Closed Atom  %%%%%
%define aca atom const unit %.
%%%%%  Symmetry  %%%%%
%sort atom-eq-symm {_ atom-eq R R'} {_ atom-eq R' R} %.
%mode atom-eq-symm %in %out %.
%term _ atom-eq-symm atom-eq/i atom-eq/i %.
%worlds (var) (atom-eq-symm _ _) %.
%total () (atom-eq-symm _ _) %.
%sort eterm-eq-symm {_ eterm-eq M N} {_ eterm-eq N M} %.
%mode eterm-eq-symm %in %out %.
%term _ eterm-eq-symm eterm-eq/i eterm-eq/i %.
%worlds (evar) (eterm-eq-symm _ _) %.
%total () (eterm-eq-symm _ _) %.
%sort etp-eq-symm {_ etp-eq A B} {_ etp-eq B A} %.
%mode etp-eq-symm %in %out %.
%term _ etp-eq-symm etp-eq/i etp-eq/i %.
%worlds (evar) (etp-eq-symm _ _) %.
%total () (etp-eq-symm _ _) %.
%sort term-eq-symm {_ term-eq M N} {_ term-eq N M} %.
%mode term-eq-symm %in %out %.
%term _ term-eq-symm term-eq/i term-eq/i %.
%worlds (var) (term-eq-symm _ _) %.
%total () (term-eq-symm _ _) %.
%sort tp-eq-symm {_ tp-eq A B} {_ tp-eq B A} %.
%mode tp-eq-symm %in %out %.
%term _ tp-eq-symm tp-eq/i tp-eq/i %.
%worlds (var) (tp-eq-symm _ _) %.
%total () (tp-eq-symm _ _) %.
%%%%%  Transitivity  %%%%%
%sort atom-eq-trans {_ atom-eq R1 R2} {_ atom-eq R2 R3} {_ atom-eq R1 R3} %.
%mode atom-eq-trans %in %in %out %.
%term _ atom-eq-trans atom-eq/i atom-eq/i atom-eq/i %.
%worlds (var) (atom-eq-trans _ _ _) %.
%total () (atom-eq-trans _ _ _) %.
%sort stp-eq-trans {_ stp-eq T1 T2} {_ stp-eq T2 T3} {_ stp-eq T1 T3} %.
%mode stp-eq-trans %in %in %out %.
%term _ stp-eq-trans stp-eq/i stp-eq/i stp-eq/i %.
%worlds () (stp-eq-trans _ _ _) %.
%total () (stp-eq-trans _ _ _) %.
%sort term-eq-trans {_ term-eq M N} {_ term-eq N O} {_ term-eq M O} %.
%mode term-eq-trans %in %in %out %.
%term _ term-eq-trans term-eq/i term-eq/i term-eq/i %.
%worlds (var) (term-eq-trans _ _ _) %.
%total () (term-eq-trans _ _ _) %.
%sort tp-eq-trans {_ tp-eq A B} {_ tp-eq B C} {_ tp-eq A C} %.
%mode tp-eq-trans %in %in %out %.
%term _ tp-eq-trans tp-eq/i tp-eq/i tp-eq/i %.
%worlds (var) (tp-eq-trans _ _ _) %.
%total () (tp-eq-trans _ _ _) %.
%%%%%  Cons Lemmas  %%%%%
%sort app-resp {_ atom-eq R R'} {_ term-eq M M'} {_ atom-eq (app R M) (app R' M')} %.
%mode app-resp %in %in %out %.
%term _ app-resp atom-eq/i term-eq/i atom-eq/i %.
%worlds (var) (app-resp _ _ _) %.
%total () (app-resp _ _ _) %.
%sort atom-resp-atom {R %pi atom %-> atom} {_ atom-eq Q Q'} {_ atom-eq (R Q) (R Q')} %.
%mode atom-resp-atom %in %in %out %.
%term _ atom-resp-atom _ atom-eq/i atom-eq/i %.
%worlds (var) (atom-resp-atom _ _ _) %.
%total () (atom-resp-atom _ _ _) %.
%sort atom-resp-term {R %pi term %-> atom} {_ term-eq M M'} {_ atom-eq (R M) (R M')} %.
