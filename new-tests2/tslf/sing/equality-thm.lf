%mode atom-resp-tp %in %in %out %.
%term _ atom-resp-tp _ tp-eq/i atom-eq/i %.
%worlds (var) (atom-resp-tp _ _ _) %.
%total () (atom-resp-tp _ _ _) %.
%sort cons-resp {_ ctx-eq G G'} {_ atom-eq X X'} {_ tp-eq A A'} {_ ctx-eq (cons G X A) (cons G' X' A')} %.
%mode cons-resp %in %in %in %out %.
%term _ cons-resp ctx-eq/i atom-eq/i tp-eq/i ctx-eq/i %.
%worlds (var) (cons-resp _ _ _ _) %.
%total () (cons-resp _ _ _ _) %.
%sort elam-resp {_ etp-eq A A'} {_ {x} eterm-eq (M x) (M' x)} {_ eterm-eq (elam A M) (elam A' M')} %.
%mode elam-resp %in %in %out %.
