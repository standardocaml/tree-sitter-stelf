%worlds (evar ebind eofblock) (equiv-resp _ _ _ _ _) %.
%total () (equiv-resp _ _ _ _ _) %.
%sort esigma-resp {_ etp-eq A A'} {_ {x} etp-eq (B x) (B' x)} {_ etp-eq (esigma A B) (esigma A' B')} %.
