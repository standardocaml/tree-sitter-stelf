%scope wf-to-wfe %term t wf-to-wfe wf/t (wfe/t ordered/nil) %.
%term pi 
	%pi (wf-to-wfe (wf/pi D2 D1) (wfe/pi D2' D1'))
	%<- (wf-to-wfe D1 D1')
	%<- (wf1-to-wfe 0 D2 D2') %.
%scope wf-to-wfe %term sigma 
	%pi (wf-to-wfe (wf/sigma D2 D1) (wfe/sigma D2' D1'))
	%<- (wf-to-wfe D1 D1')
	%<- (wf1-to-wfe 0 D2 D2') %.
%term sing %pi (wf-to-wfe (wf/sing D) (wfe/sing D')) %<- (aof-to-aofe D D') %.
%worlds (var bind ovar) (wf-to-wfe _ _) %.
