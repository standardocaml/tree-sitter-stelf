	%pi (maof (aof/app Dwf _ Dof Daof) (mapp Dwf' Dof' Daof'))
	%<- (maof Daof Daof')
	%<- (mof Dof Dof')
	%<- (mwf Dwf Dwf') %.
%term maof/pi1 %pi (maof (aof/pi1 Daof) (mpi1 Daof')) %<- (maof Daof Daof') %.
%term maof/pi2 %pi (maof (aof/pi2 Daof) (mpi2 Daof')) %<- (maof Daof Daof') %.
%term mwf/t mwf wf/t mt %.
%term mwf/pi 
	%pi (mwf (wf/pi Dwf2 Dwf1) (mpi Dwf2' Dwf1'))
	%<- (mwf Dwf1 Dwf1')
	%<- ({x} {d} mwf (Dwf2 x d) Dwf2') %.
%term mwf/sigma 
