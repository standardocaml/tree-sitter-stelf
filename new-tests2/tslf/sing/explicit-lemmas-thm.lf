	%<- ({x} {d vof x A} can-mwf (Dwf x d) (%the (mwf (Dwf x d) Bm) (Dmwf x d)))
	%<- (cut-wf Bm Dwf Dmwf ([x] [d'] lookup/hit (bounded/nil d')) (%the ({x} %pi (isvar x I) %-> (wfe (cons nil x A) (B x))) Dwfe) _) %.
%worlds (var bind ovar) (wf1-to-wfe _ _ _) %.
%total () (wf1-to-wfe _ _ _) %.
%sort aof-to-aofe {_ aof R A} {_ aofe nil R A} %.
