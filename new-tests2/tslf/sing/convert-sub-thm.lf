%%%%%  Conversion Commutes with Simple Substitution (Explicit Context)  %%%%%
%sort strengthen-vtrans {_ {x} {ex} %pi (vtrans ex x) %-> (vtrans (EX ex) X)} {_ {ex} eterm-eq (EX ex) EX'} {_ vtrans EX' X} %.
%mode strengthen-vtrans %in %out %out %.
%term _ strengthen-vtrans ([x] [ex] [d] D) ([ex] eterm-eq/i) D %.
%worlds (bind ovar tbind evar) (strengthen-vtrans _ _ _) %.
%total () (strengthen-vtrans _ _ _) %.
%sort convert-ssub-e {_ {x} append (cons G1 x A) (G2 x) (G x)} {_ append G1 (G2 R) G'} {_ {x} 
	%pi (isvar x I)
	%-> ({ex} %pi (vtrans ex x) %-> (converte (G x) (N x) (B x) (EN ex)))} {_ aconverte G1 R A EM} {_ converte G' (N R) (B R) (EN EM)} %.
