	%<- (tconvert-ssub-e Dappend Dappend' DconvA Dconv DconvA')
	%<- ({y} {e} {ey} {yt} tconvert-ssub-e ([x] append/cons (Dappend x)) (append/cons Dappend') ([x] [d] [ex] [xt] DconvB x d ex xt y e ey yt) Dconv (DconvB' y e ey yt)) %.
%scope tconvert-ssub-e %term sigma 
	%pi (tconvert-ssub-e Dappend Dappend' ([x] [d] [ex] [xt] tconverte/sigma (DconvB x d ex xt) (DconvA x d ex xt)) Dconv (tconverte/sigma DconvB' DconvA'))
