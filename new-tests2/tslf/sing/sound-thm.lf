	%-> (vsound f zt (tconvert/sigma DconvertB DconvertA) ef)
	%-> (convert-ssub (Dconvert2 z f ez zt) (%the (aconvert (pi2 z) (B (pi1 z)) (epi2 ez)) (aconvert/pi2 (aconvert/var zt (tconvert/sigma DconvertB DconvertA) (wf/sigma DwfB DwfA) f))) (%the (convert (N (pi1 z) (pi2 z)) (Dx (pi1 z)) (EN (epi1 ez) (epi2 ez))) (Dconvert2' z f ez zt))))
	%<- ({x} {d vof x C} {ex} {xt vtrans ex x} tconvert-reg-il (DconvertD x d ex xt) (%the (wf (D x)) (DwfD x d)))
	%<- ({z} {f vof z (sigma A B)} {ez} {zt vtrans ez z} {ef evof ez (esigma EA EB)} {fv variable ez} 
