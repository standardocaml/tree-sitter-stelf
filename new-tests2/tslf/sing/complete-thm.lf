%%%%%  Completeness  %%%%%
%sort etopen-fun {_ etopen Ac A} {_ etopen Ac A'} {_ etp-eq A A'} %.
%mode etopen-fun %in %in %out %.
%term _ etopen-fun etopen/t etopen/t etp-eq/i %.
%term _ 
	%pi (etopen-fun (etopen/pi D2 D1) (etopen/pi D2' D1') Deq)
	%<- (etopen-fun D1 D1' Deq1)
	%<- (etopen-fun D2 D2' Deq2)
	%<- (epi-resp Deq1 ([_] Deq2) Deq) %.
%worlds (evar) (etopen-fun _ _ _) %.
%total D (etopen-fun D _ _) %.
%sort trans-topen {_ etopen Ac EA} {_ ttrans EA A} {_ topen Ac A} %.
%mode trans-topen %in %out %out %.
%scope trans-topen %term t trans-topen etopen/t ttrans/t topen/t %.
%term pi 
	%pi (trans-topen (etopen/pi Dopen2 Dopen1) (ttrans/pi ([_] [_] [_] [_] Dtrans2) Dtrans1) (topen/pi Dopen2' Dopen1'))
	%<- (trans-topen Dopen1 Dtrans1 Dopen1')
	%<- (trans-topen Dopen2 Dtrans2 Dopen2') %.
%worlds (bind tbind) (trans-topen _ _ _) %.
%total D (trans-topen D _ _) %.
%sort kof-comp {_ ekof C EA} {_ ttrans EA A} {_ kof C A} %.
%mode kof-comp %in %in %out %.
%term _ 
	%pi (kof-comp (ekof/i (%the (etopen As EA) Deopen) (%the (ckof K As) Dckof)) (%the (ttrans EA A) Dtrans) (kof/i Dopen' Dckof))
	%<- (trans-topen Deopen Dtrans' Dopen)
	%<- (ttrans-fun Dtrans' Dtrans Deq)
	%<- (topen-resp ctp-eq/i Deq Dopen Dopen') %.
%worlds (bind tbind) (kof-comp _ _ _) %.
%total () (kof-comp _ _ _) %.
%sort vof-comp {_ evof EM EA} {_ ttrans EA A} {_ vtrans EM X} {_ vof X A} %.
%mode vof-comp %in %out %out %out %.
%sort of-comp {_ eof EM EA} {_ ttrans EA A} {_ trans EM B} {_ subtype B A _} %.
%mode of-comp %in %out %out %out %.
%sort wf-comp {_ ewf EA} {_ ttrans EA A} %.
%mode wf-comp %in %out %.
%sort subtp-comp {_ subtp EA EB} {_ ttrans EA A} {_ ttrans EB B} {_ subtype A B _} %.
%mode subtp-comp %in %out %out %out %.
%sort tequiv-comp {_ tequiv EA EB} {_ ttrans EA A} {_ ttrans EB A} %.
%mode tequiv-comp %in %out %out %.
%sort equiv-comp {_ equiv EM EN EA} {_ ttrans EA A} {_ trans EM B} {_ trans EN C} {_ subtype B A M} {_ subtype C A M} %.
%mode equiv-comp %in %out %out %out %out %out %.
%block cbind {x atom} {a tp} {ea etp} {d_ttrans ttrans ea a} {d_vof vof x a} [ex eterm] [xt vtrans ex x] [ed evof ex ea] [thm1 vof-comp ed d_ttrans xt d_vof]%.
