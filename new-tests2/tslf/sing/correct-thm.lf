%total D (coerce-convert _ _ D _) %.
%sort coerce-convert' {_ tconvert A EA} {_ tconvert B EB} {_ coerce EA EB EM} {_ subtype A B M} {_ {x} %pi (vof x A) %-> ({ex} %pi (vtrans ex x) %-> (convert (M x) B (EM ex)))} %.
