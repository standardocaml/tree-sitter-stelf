	%pi (subtype-reg-e subtype/t (wfe/t (%the (ordered G) Dordered)) (wfe/t _) ([x] [d isvar x I] ofe/at (aofe/var (wfe/t (ordered/cons (Dbounded x d))) (lookup/hit (Dbounded x d)))))
	%<- (extend-context Dordered (%the ({x} %pi (isvar x I) %-> (bounded G x)) Dbounded)) %.
