	%<- ({z} {f isvar z I} {x} {d isvar x J} weakeng-wfe (append/cons append/nil) (append/cons append/nil) (ordered/cons (bounded/cons (Dbounded z f) (DprecedesIJ z f x d))) (DwfA2''' x d) (%the (wfe (cons (cons G z (pi A1 A2)) x B1) (A2' x)) (DwfA2'''' z f x d)))
