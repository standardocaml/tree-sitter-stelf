%scope sub-expand-var-em %term pi 
	%pi (expand-aosub-em _ _ nat-eq/i ([x] simp/pi (%the ({y} simp (C x y) T) (DsimpC x)) (%the (simp (B x) S) (DsimpB x))) (%the ({x} append (cons G1 x A) (G2 x) (G x)) Dappend) (%the (csub G M Gx) Dcsub) (%the (ofe G1 M A) DofM) (%the ({x} %pi (isvar x I) %-> (aofe (G x) (R x) (pi (B x) ([y] C x y)))) DofR) ([x] %the (expand (R x) (pi (B x) ([y] C x y)) (lam ([y] O x y))) (expand/pi (%the ({y} expand (app (R x) (N x y)) (C x y) (O x y)) (Dexpand2 x)) (%the ({y} expand y (B x) (N x y)) (Dexpand1 x)))) (%the (aosub ([x] R x) M (lam ([y] P y))) Daosub) (sub/lam Dsub))
