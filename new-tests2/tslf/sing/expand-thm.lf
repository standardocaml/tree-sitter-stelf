	%<- ({x} {d isvar x I} {y} {e isvar y J} wfe-context (DwfC x d y e) (ordered/cons (%the (bounded (G x) y) (Dbounded x d y e))))
	%<- ({x} {d isvar x I} {y} {e isvar y J} weaken-wfe (Dbounded x d y e) (DwfB x d) _ (%the (wfe (cons (G x) y (B x)) (B x)) (DwfB' x d y e)))
