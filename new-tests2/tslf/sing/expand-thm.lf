	%<- ({x} {d vof x A} sub-expand (aof/var DwfA d) DofM (Dexpand x) (Dsub x) (%the (term-eq (M' x) (M x)) (Deq x)))
	%<- ({x} sub-resp ([_] term-eq/i) term-eq/i (Deq x) (Dsub x) (%the (sub ([y] M y) (X x) (M x)) (Dsub' x))) %.
