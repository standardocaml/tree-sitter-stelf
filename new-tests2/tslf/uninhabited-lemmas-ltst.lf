%%%% lemmas that take the uninhabited judgment as input.
%%%% when you are nowhere, anything is possible!
%sort uninhabited-oflt {S st} {L lt} {T lt} {_ uninhabited} {_ oflt S L T} %.
%mode uninhabited-oflt %in %in %in %in %out %.
%worlds (ofsg-block oftp-block ofkd-block ofsg+vdt-block oftp+vdt-block ofkd+vdt-block) (uninhabited-oflt _ _ _ _ _) %.
%total () (uninhabited-oflt _ _ _ _ _) %.
%sort uninhabited-lt-sub {S1 lt} {S2 lt} {_ uninhabited} {_ lt-sub S1 S2} %.
%mode uninhabited-lt-sub %in %in %in %out %.
%worlds (ofsg+vdt-block oftp+vdt-block ofkd+vdt-block) (uninhabited-lt-sub _ _ _ _) %.
%total () (uninhabited-lt-sub _ _ _ _) %.
%sort uninhabited-st-wf {_ uninhabited} {L lt} {E st} {C lt} {T lt} {_ st-wf L E C T} %.
%mode uninhabited-st-wf %in %in %in %in %in %out %.
%worlds (ofsg-block oftp-block ofkd-block ofsg+vdt-block oftp+vdt-block ofkd+vdt-block) (uninhabited-st-wf _ _ _ _ _ _) %.
%total () (uninhabited-st-wf _ _ _ _ _ _) %.