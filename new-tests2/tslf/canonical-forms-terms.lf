	%<- (neq/deq/cross-unit Deq Dun)
	%<- (uninhabited-seq/tm _ _ Dun Dseq) %.
%term _ 
	%pi (cfl/tp/unit val/tm/fun (oftp/tm/fun _ _) Deq Dseq)
