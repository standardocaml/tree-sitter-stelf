	%<- (neq/deq/sum-unit Deq Dun)
	%<- (uninhabited-seq/tm _ _ Dun Dseq) %.
%term _ 
	%pi (cfl/tp/unit (val/tm/inr _) (oftp/tm/inr _ _) Deq Dseq)
	%<- (neq/deq/sum-unit Deq Dun)
	%<- (uninhabited-seq/tm _ _ Dun Dseq) %.
%term _ 
