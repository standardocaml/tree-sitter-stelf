	%<- (neq/deq/mu-unit Deq Dun)
	%<- (uninhabited-seq/tm _ _ Dun Dseq) %.
%worlds () (cfl/tp/unit _ _ _ _) %.
%total D1 (cfl/tp/unit _ D1 _ _) %.
