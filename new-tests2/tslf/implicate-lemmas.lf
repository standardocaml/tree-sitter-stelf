%%%% lemmas needed for implcate
% "halfway" explicit semantics?
%sort ikd-wf {_ cxt} {_ kd} %.
%term ikd-wf/nil %pi (ikd-wf cxt/nil K) %<- (kd-wf K) %.
%term ikd-wf/cons %pi (ikd-wf (cxt/cons G C K) K') %<- (%pi (ofkd C K) %-> (ikd-wf G K')) %.
%sort iofkd {_ cxt} {_ cn} {_ kd} %.
%term iofkd/nil %pi (iofkd cxt/nil C K) %<- (ofkd C K) %.
%term iofkd/cons %pi (iofkd (cxt/cons G C K) C' K') %<- (%pi (ofkd C K) %-> (iofkd G C' K')) %.
%sort ikd-sub {_ cxt} {_ kd} {_ kd} %.
%term ikd-sub/nil %pi (ikd-sub cxt/nil K K') %<- (kd-sub K K') %.
%term ikd-sub/cons %pi (ikd-sub (cxt/cons G C K) K1 K2) %<- (%pi (ofkd C K) %-> (ikd-sub G K1 K2)) %.
%sort ikd-deq {_ cxt} {_ kd} {_ kd} %.
%term ikd-deq/nil %pi (ikd-deq cxt/nil K K') %<- (kd-deq K K') %.
%term ikd-deq/cons %pi (ikd-deq (cxt/cons G C K) K1 K2) %<- (%pi (ofkd C K) %-> (ikd-deq G K1 K2)) %.
%sort icn-deq {_ cxt} {_ cn} {_ cn} {_ kd} %.
%term icn-deq/nil %pi (icn-deq cxt/nil C1 C2 K) %<- (cn-deq C1 C2 K) %.
%term icn-deq/cons 
	%pi (icn-deq (cxt/cons G C K) C1 C2 K')
	%<- (%pi (ofkd C K) %-> (icn-deq G C1 C2 K')) %.
%block iofkd-block {c cn} {k kd} [d ofkd c k]%.
%sort kd-wf-to-ikd-wf {G cxt} {_ kd-wf K} {_ ikd-wf G K} %.
%mode kd-wf-to-ikd-wf %in %in %out %.
%term _ kd-wf-to-ikd-wf cxt/nil D (ikd-wf/nil D) %.
%term _ 
	%pi (kd-wf-to-ikd-wf (cxt/cons G C K) D (ikd-wf/cons ([d] D')))
	%<- (kd-wf-to-ikd-wf G D D') %.
%worlds (ovar-block iofkd-block ofkd-block) (kd-wf-to-ikd-wf _ _ _) %.
%total G (kd-wf-to-ikd-wf G _ _) %.
