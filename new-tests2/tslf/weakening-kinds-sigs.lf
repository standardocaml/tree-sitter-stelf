%%%% weakening lemma for kinds. 
%sort kd-wkn/sg-wf {_ {a cn} {da ofkd a K2} sg-wf (S a)} {_ kd-sub K1 K2} {_ {a cn} {da ofkd a K1} sg-wf (S a)} %.
%mode kd-wkn/sg-wf %in %in %out %.
%term _ kd-wkn/sg-wf DI DS ([a] [da] DI a (ofkd/sub da DS)) %.
%worlds (ofkd-block) (kd-wkn/sg-wf _ _ _) %.
%total () (kd-wkn/sg-wf _ _ _) %.
%sort kd-wkn/sg-sub {_ {a cn} {da ofkd a K2} sg-sub (S' a) (S'' a)} {_ kd-sub K1 K2} {_ {a cn} {da ofkd a K1} sg-sub (S' a) (S'' a)} %.
%mode kd-wkn/sg-sub %in %in %out %.
%term _ kd-wkn/sg-sub DI DS ([a] [da] DI a (ofkd/sub da DS)) %.
%worlds (ofkd-block) (kd-wkn/sg-sub _ _ _) %.
%total () (kd-wkn/sg-sub _ _ _) %.
%sort kd-wkn/sg-deq {_ {a cn} {da ofkd a K2} sg-deq (S' a) (S'' a)} {_ kd-sub K1 K2} {_ {a cn} {da ofkd a K1} sg-deq (S' a) (S'' a)} %.
%mode kd-wkn/sg-deq %in %in %out %.
%term _ kd-wkn/sg-deq DI DS ([a] [da] DI a (ofkd/sub da DS)) %.
%worlds (ofkd-block) (kd-wkn/sg-deq _ _ _) %.
%total () (kd-wkn/sg-deq _ _ _) %.