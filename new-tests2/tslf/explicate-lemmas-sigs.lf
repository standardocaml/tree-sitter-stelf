	%<- (cut-cn-deq Mm D1 D2 DL D1' D2') %.
%term _ 
	%pi (cut-sg-deq (met/sing Mm) ([d] sg-deq/sg/kd (D1 d)) ([d'] [dm] msg-deq/sg/kd (D2 d' dm)) DL (esg-deq/sg/kd D1') (mesg-deq/sg/kd D2'))
	%<- (cut-kd-deq Mm D1 D2 DL D1' D2') %.
%term _ 
