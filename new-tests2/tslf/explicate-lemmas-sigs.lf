	%<- ({y} {e' isvar y J} cut-esg-wf M2 ([d] D2' d y e') ([d] [dm] D4' d dm y e') (DL' y e') (D2'' y e') (D4'' y e')) %.
%term _ 
	%pi (cut-sg-deq _ ([d] sg-deq/sg/unit) ([d'] [dm] msg-deq/sg/unit) DL (esg-deq/sg/unit DO) mesg-deq/sg/unit)
	%<- (cxt-lookup-ordered DL DO) %.
%term _ 
