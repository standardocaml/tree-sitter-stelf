%term _ 
	%pi (cut-esg-deq (met/sing Mm) ([d] esg-deq/sg/cn (D1 d)) ([d] [dm] mesg-deq/sg/cn (D2 d dm)) DL (esg-deq/sg/cn D1') (mesg-deq/sg/cn D2'))
