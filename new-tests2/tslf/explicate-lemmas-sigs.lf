	%<- ({y} {e' isvar y J} cut-esg-wf M2 ([d] D2' d y e') ([d] [dm] D4' d dm y e') (DL' y e') (D2'' y e') (D4'' y e')) %.
%term _ 
	%pi (cut-sg-wf (met/pair M1 M2) ([d] sg-wf/sg/pi (D1 d) (D2 d) DFS) ([d'] [dm] msg-wf/sg/pi (D3 d' dm) (D4 d' dm)) DL (esg-wf/sg/pi D1' D2'' DFS) (mesg-wf/sg/pi D3' D4''))
