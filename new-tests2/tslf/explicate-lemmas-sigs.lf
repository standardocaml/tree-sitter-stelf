%sort cut-sg-wf {Cm} {D %pi (ofkd C K) %-> (sg-wf K')} {_ {d} %pi (mofkd d met/unit) %-> (msg-wf (D d) Cm)} {_ cxt-lookup G C K} {D' esg-wf G K'} {_ mesg-wf D' Cm} %.
%mode cut-sg-wf %in %in %in %in %out %out %.
%sort cut-sg-deq {Cm} {D %pi (ofkd C K) %-> (sg-deq K' K'')} {_ {d} %pi (mofkd d met/unit) %-> (msg-deq (D d) Cm)} {_ cxt-lookup G C K} {D' esg-deq G K' K''} {_ mesg-deq D' Cm} %.
%mode cut-sg-deq %in %in %in %in %out %out %.
%sort cut-esg-wf {Cm} {D %pi (ofkd C K) %-> (esg-wf G K')} {_ {d} %pi (mofkd d met/unit) %-> (mesg-wf (D d) Cm)} {_ cxt-lookup G C K} {D' esg-wf G K'} {_ mesg-wf D' Cm} %.
%mode cut-esg-wf %in %in %in %in %out %out %.
%sort cut-esg-deq {Cm} {D %pi (ofkd C K) %-> (esg-deq G K' K'')} {_ {d} %pi (mofkd d met/unit) %-> (mesg-deq (D d) Cm)} {_ cxt-lookup G C K} {D' esg-deq G K' K''} {_ mesg-deq D' Cm} %.
%mode cut-esg-deq %in %in %in %in %out %out %.
%term _ 
	%pi (cut-sg-wf _ ([d] sg-wf/sg/unit) ([d'] [dm] msg-wf/sg/unit) DL (esg-wf/sg/unit DO) mesg-wf/sg/unit)
	%<- (cxt-lookup-ordered DL DO) %.
%term _ 
	%pi (cut-sg-wf (met/sing Mm) ([d] sg-wf/sg/cn (D1 d)) ([d'] [dm] msg-wf/sg/cn (D2 d' dm)) DL (esg-wf/sg/cn D1') (mesg-wf/sg/cn D2'))
	%<- (cut-ofkd Mm D1 D2 DL D1' D2') %.
%term _ 
	%pi (cut-sg-wf (met/sing Mm) ([d] sg-wf/sg/kd (D1 d)) ([d'] [dm] msg-wf/sg/kd (D2 d' dm)) DL (esg-wf/sg/kd D1') (mesg-wf/sg/kd D2'))
	%<- (cut-kd-wf Mm D1 D2 DL D1' D2') %.
%term _ 
