	%pi (cut-esg-wf (met/sing Mm) ([d] esg-wf/sg/cn (D1 d)) ([d] [dm] mesg-wf/sg/cn (D2 d dm)) DL (esg-wf/sg/cn D1') (mesg-wf/sg/cn D2'))
