%%%% lemmas about syntactic equality
%%%% this file could benefit from better organization. perhaps splitting it
%%%% into different files, etc..
%sort seq/val/tm {_ seq/tm E1 E2} {_ val/tm E1} {_ val/tm E2} %.
%mode seq/val/tm %in %in %out %.
%term _ seq/val/tm seq/tm/refl D1 D1 %.
%worlds (ofkd+vdt-block) (seq/val/tm _ _ _) %.
%total () (seq/val/tm _ _ _) %.
%sort seq/val/md {_ seq/md M1 M2} {_ val/md M1} {_ val/md M2} %.
%mode seq/val/md %in %in %out %.
%term _ seq/val/md seq/md/refl D1 D1 %.
%worlds (ofkd+vdt-block) (seq/val/md _ _ _) %.
%total () (seq/val/md _ _ _) %.
%sort step/tm/seq {_ seq/tm T2 T1} {_ step/tm T1 S1 TT1 T3 S2 TT2} {_ step/tm T2 S1 TT1 T3 S2 TT2} %.
%mode step/tm/seq %in %in %out %.
%term _ step/tm/seq seq/tm/refl S1 S1 %.
%worlds () (step/tm/seq _ _ _) %.
%total () (step/tm/seq _ _ _) %.
%sort step/md/seq {_ seq/md M2 M1} {_ step/md M1 S1 T1 M3 S2 T2} {_ step/md M2 S1 T1 M3 S2 T2} %.
%mode step/md/seq %in %in %out %.
%term _ step/md/seq seq/md/refl S1 S1 %.
%worlds () (step/md/seq _ _ _) %.
%total () (step/md/seq _ _ _) %.