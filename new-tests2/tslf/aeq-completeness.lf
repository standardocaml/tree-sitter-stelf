%%%% algorithmic equivalence for constructors a la SH
%sort aeq-complete {_ cn-deq C1 C2 K} {_ cn-aeq C1 C2 K} %.
%mode aeq-complete %in %out %.
%worlds (ofkd+vdt-block) (aeq-complete _ _) %.
%total () (aeq-complete _ _) %.
%sort cn-aeq-sound {_ cn-aeq C1 C2 K} {_ cn-deq C1 C2 K} %.
%mode cn-aeq-sound %in %out %.
%worlds (ofkd-block) (cn-aeq-sound _ _) %.
%total () (cn-aeq-sound _ _) %.
%sort kd-aeq-sound {_ kd-aeq C1 C2} {_ kd-deq C1 C2} %.
%mode kd-aeq-sound %in %out %.
%term _ kd-aeq-sound kd-aeq/kd/unit kd-deq/kd/unit %.
%term _ kd-aeq-sound kd-aeq/kd/type kd-deq/kd/type %.
%term _ 
	%pi (kd-aeq-sound (kd-aeq/kd/sing D1) (kd-deq/kd/sing D2))
	%<- (cn-aeq-sound D1 D2) %.
%term _ 
	%pi (kd-aeq-sound (kd-aeq/kd/sgm D1 D2) (kd-deq/kd/sgm D1' D2'))
	%<- (kd-aeq-sound D1 D1')
	%<- ({a} {da} kd-aeq-sound (D2 a da) (D2' a da)) %.
%term _ 
	%pi (kd-aeq-sound (kd-aeq/kd/pi D1 D2) (kd-deq/kd/pi D1' D2'))
	%<- (kd-aeq-sound D1 D1')
	%<- ({a} {da} kd-aeq-sound (D2 a da) (D2' a da)) %.
%worlds (ofkd-block) (kd-aeq-sound _ _) %.
%total D1 (kd-aeq-sound D1 _) %.
