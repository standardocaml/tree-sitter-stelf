%sort inv/ofkd/tp/forall {_ ofkd (tp/forall K' C) K} {_ kd-sub K kd/type} {_ kd-wf K'} {_ {a} {da ofkd a K'} ofkd (C a) kd/type} %.
%mode inv/ofkd/tp/forall %in %in %out %out %.
%term _ inv/ofkd/tp/forall (ofkd/tp/forall D2 D1) _ D1 D2 %.
%term _ 
	%pi (inv/ofkd/tp/forall (ofkd/kd/sing DC) _ D1 D2)
