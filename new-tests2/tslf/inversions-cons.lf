%mode inv/ofkd/tp/tag %in %in %out %.
%term _ inv/ofkd/tp/tag (ofkd/tp/tag D1) _ D1 %.
%term _ 
	%pi (inv/ofkd/tp/tag (ofkd/kd/sing DC) _ D1)
	%<- (inv/ofkd/tp/tag DC kd-sub/kd/type D1) %.
