%%%% simple inversion lemmas
%sort inv/ofkd/tp/cross {_ ofkd (tp/cross C1 C2) K} {_ kd-sub K kd/type} {_ ofkd C1 kd/type} {_ ofkd C2 kd/type} %.
%mode inv/ofkd/tp/cross %in %in %out %out %.
%term _ inv/ofkd/tp/cross (ofkd/tp/cross D1 D2) _ D1 D2 %.
%term _ 
	%pi (inv/ofkd/tp/cross (ofkd/kd/sing DC) _ D1 D2)
	%<- (inv/ofkd/tp/cross DC kd-sub/kd/type D1 D2) %.
%term _ 
	%pi (inv/ofkd/tp/cross (ofkd/sub DC DS) KS D1 D2)
	%<- (kd-trans/sub DS KS DS')
	%<- (inv/ofkd/tp/cross DC DS' D1 D2) %.
%term _ 
	%pi (inv/ofkd/tp/cross (ofkd/deq DC DQ) KS D1 D2)
	%<- (vdt/kd-deq DQ DQ1 DQ2)
	%<- (kd-anti DQ DQ1 DQ2 DS _)
	%<- (kd-trans/sub DS KS DS')
	%<- (inv/ofkd/tp/cross DC DS' D1 D2) %.
%worlds (ofkd+vdt-block) (inv/ofkd/tp/cross _ _ _ _) %.
%total D1 (inv/ofkd/tp/cross D1 _ _ _) %.
%sort inv/ofkd/tp/arrow {_ ofkd (tp/arrow C1 C2) K} {_ kd-sub K kd/type} {_ ofkd C1 kd/type} {_ ofkd C2 kd/type} %.
