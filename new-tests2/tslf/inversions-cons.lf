	%<- (inv/ofkd/tp/arrow DC DS' D1 D2) %.
%worlds (ofkd+vdt-block) (inv/ofkd/tp/arrow _ _ _ _) %.
%total D1 (inv/ofkd/tp/arrow D1 _ _ _) %.
