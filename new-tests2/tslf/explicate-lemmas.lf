	%pi (cut-kd-wf (met/pair M1 M2) ([d] kd-wf/kd/pi (D1 d) (D2 d)) ([d'] [dm] mkd-wf/kd/pi (D3 d' dm) (D4 d' dm)) DL (ekd-wf/kd/pi D1' D2'') (mekd-wf/kd/pi D3' D4''))
