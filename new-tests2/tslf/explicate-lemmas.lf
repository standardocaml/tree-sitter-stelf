%term _ 
	%pi (cut-kd-wf _ ([d] kd-wf/kd/unit) ([d'] [dm] mkd-wf/kd/unit) DL (ekd-wf/kd/unit DO) mekd-wf/kd/unit)
	%<- (cxt-lookup-ordered DL DO) %.
%term _ 
	%pi (cut-kd-wf _ ([d] kd-wf/kd/type) ([d'] [dm] mkd-wf/kd/type) DL (ekd-wf/kd/type DO) mekd-wf/kd/type)
