	%<- ({d ofkd X A} {dm mofkd d met/unit} {y} {e' isvar y J} cut-kd-wf M2 ([e] D2 d y e) ([e] [em] D4 d dm y e em) (cxt-lookup/hit (DB y e')) (%the (ekd-wf (cxt/cons G y B) (C y)) (D2' d y e')) (%the (mekd-wf (D2' d y e') M2) (D4' d dm y e')))
	%<- ({y} {e' isvar y J} cut-ekd-wf M2 ([d] D2' d y e') ([d] [dm] D4' d dm y e') (DL' y e') (D2'' y e') (D4'' y e')) %.
