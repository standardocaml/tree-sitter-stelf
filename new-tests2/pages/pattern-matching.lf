%term _ 
	%pi (preservation-subst-oexp (of-explist/s D1 D) (of-oexp/s D2) (subst-oexp/s D3) D4)
	%<- (preservation-subst-oexp D1 (D2 _ D) D3 D4) %.
%worlds () (preservation-subst-oexp _ _ _ _) %.
%total (D1) (preservation-subst-oexp _ _ D1 _) %.
%sort preservation-append {_ of-explist EL1 TL1} {_ of-explist EL2 TL2} {_ explist-append EL1 EL2 EL3} {_ tplist-append TL1 TL2 TL3} {_ of-explist EL3 TL3} %.
%mode preservation-append %in %in %in %in %out %.
%term _ preservation-append _ D explist-append/z tplist-append/z D %.
%term _ 
	%pi (preservation-append (of-explist/s D1 D) D2 (explist-append/s D3) (tplist-append/s D4) (of-explist/s D5 D))
	%<- (preservation-append D1 D2 D3 D4 D5) %.
