%term _ progress-pair (notstuck/raises DS) _ (notstuck/raises (raises/pair-1 DS)) %.
%term _ progress-pair (notstuck/value V) (notstuck/raises DS) (notstuck/raises (raises/pair-2 DS V)) %.
%term _ progress-pair (notstuck/value DV1) (notstuck/value DV2) (notstuck/value (value/pair DV2 DV1)) %.
%worlds () (progress-pair _ _ _) %.
%total () (progress-pair _ _ _) %.
%sort progress-inl {_ notstuck E1} {_ notstuck (exp/inl E1)} %.
%mode progress-inl %in %out %.
%term _ progress-inl (notstuck/step DS) (notstuck/step (step/inl DS)) %.
