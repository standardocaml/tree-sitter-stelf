%term frame_linear_lem1_rule 
	%pi (frame_linear_lem1 C (%the ({m} frameapply (Fs m) _ _) FA) LR FA' LR')
	%<- ({m} revFs_exists (Fs m) nil (%the (revFs (Fs m) nil (Fs' m)) (Rev m)))
