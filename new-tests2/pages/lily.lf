%term lem19_tens1 %pi (lem19 M M' FA (linear_tens1 L) Q) %<- (lem20 M M' ([a] val_tens) FA Q) %.
%term lem19_tens2 %pi (lem19 M M' FA (linear_tens2 L) Q) %<- (lem20 M M' ([a] val_tens) FA Q) %.
