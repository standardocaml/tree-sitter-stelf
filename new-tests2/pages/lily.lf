%term frame_linear_tlam_lem_nil1 frame_linear_lem2 C ([m] %the (frameapply' _ (tapp _ T) _) frameapply'_nil) (linear_tapp (linear_tlam L)) ([m] frameapply'_nil) (L T) %.
