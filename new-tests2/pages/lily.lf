%term strictness2_lem1_lett2 
	%pi (strictness2_lem1 ([a] a) Fs Ft1 (evs_lett EvM2 EvM1) (frameterm_lett Ft5))
	%<- (strictness2_lem1 ([a] a) Fs Ft1 EvM2 Ft2)
	%<- (lem42 ([a] Fs a) ([a] a) (%the (redex (lett (tens M1 M2) M3) _) redex_lett) Ft2 Ft3)
