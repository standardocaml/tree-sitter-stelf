%sort frame_linear_lem1 {_ redex_tp (%the ({m term} redex (M m) (M' m)) C) Ct} {_ {m term} frameapply (Fs m) (M m) (R m)} {_ linear R} {_ {m} frameapply (Fs m) (M' m) (R' m)} {_ linear R'} %.
