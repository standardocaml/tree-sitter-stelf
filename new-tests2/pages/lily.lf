	%pi (lem19 M M' ([a] frameapply'_cons (%the (frameapp (fapp (N2 a)) _ _) frameapp_app) (%the (frameapply' (Fs a) a M1) (FA a))) (linear_app2 L) Q)
	%<- ({y term} revFs_exists (Fs y) nil (Rev y))
	%<- ({y term} frameapply_e1 (Rev y) (FA y) (FA' y))
