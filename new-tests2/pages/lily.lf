	%pi (frame_linear_lem2 C ([m] frameapply'_cons (%the (frameapp (fletb T) (M1 m) _) frameapp_app) (FA m)) (linear_letb1 L) ([m] frameapply'_cons frameapp_app (FA' m)) (linear_letb1 L'))
	%<- (frame_linear_lem2 C FA L FA' L') %.
