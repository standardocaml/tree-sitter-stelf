	%pi (apply_linear LM LN (linear_letb1 L) ([a term] frameapply'_cons (%the (frameapp (fletb M2) _ _) frameapp_app) (FA a)) ([a term] frameapply'_cons frameapp_app (FA' a)) (linear_letb1 LR'))
	%<- (apply_linear LM LN L FA FA' LR') %.
