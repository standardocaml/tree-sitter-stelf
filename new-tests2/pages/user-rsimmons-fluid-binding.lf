%sort p6 {_ eqty T T'} {_ of (tm/fix T F) T #} {_ {x tm} %pi (of x T #) %-> (of (F x) T #)} {_ of (tm/fix T' F) T #} {_ {x tm} %pi (of x T #) %-> (of (F x) T #)} %.
