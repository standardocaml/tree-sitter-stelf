	%pi (preservation step/app2 (ok<< (%the (ofstack (f/app1 --- E2 ; K) T Bs) TK) TE Dv) (%the (ok (>> (f/app2 E1 Dv --- ; K) E2)) (ok>> (ofstack/frame (offrame/app2 TE1'') TK') TE2')))
	%<- (invf-app1 TK (%the (subset Bs Cs) Sub) (%the (eqty T (ty/arrow T1 T2)) Eq) (%the (ofstack K T2 Cs) TK') (%the (of E2 T1 Cs) TE2'))
	%<- (p1 Eq TE TE1')
