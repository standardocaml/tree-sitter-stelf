%total {(A2 A2' A2'') (D D' D'')} (hsubst_m_exists A2' D' _ _ _) (hsubst_m_exists_app A2'' D'' _ _ _ _) (hsubst_r_exists A2 D _ _) %.
%sort id/mtm {_ mtm} {_ mtm} %.
