%term _ hsubst_m_exists_app A2 _ (hsubst_r_exists_sum_r DaR1 DsR1) DsM3 DcM3 (hsubst_r_exists_sum_r (atom_app DcM3 DaR1) (hsubst_r_app DsM3 DsR1)) %.
