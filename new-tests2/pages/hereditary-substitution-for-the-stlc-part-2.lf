	%<- (hsubst_r_vacuous_id D Did) %.
%term _ 
	%pi (hsubst_r_unique (hsubst_r_app DsM' DsR') (hsubst_r_app DsM'' DsR'') DidApp)
	%<- (hsubst_r_unique DsR' DsR'' DidR)
	%<- (hsubst_m_unique DsM' DsM'' DidM)
