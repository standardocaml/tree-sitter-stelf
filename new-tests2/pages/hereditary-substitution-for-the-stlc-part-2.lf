%term _ 
	%pi (hsubst_rr_unique (hsubst_rr_snd DsR') (hsubst_rr_snd DsR'') DidMr DidAr)
	%<- (hsubst_rr_unique DsR' DsR'' DidPair DidProd)
	%<- (id/tp_prod_inv DidProd _ DidAr)
