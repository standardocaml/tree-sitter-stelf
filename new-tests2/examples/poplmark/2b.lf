%term _ 
	%pi (preservation' _ (%the (of _ (record _ TRunique)) (of_record ERof TRord ERord)) (step_rec_exp ERstep) (of_record ER'of TRord ER'ord))
	%<- (unique_trans_order TRunique TRord TR'unique)
	%<- (preservation_erow _ ERof TR'unique ERord ERstep ER'of ER'ord) %.
%term _ 
	%pi (preservation' _ (of_proj LT Eof) (step_proj_rec Estep) (of_proj LT E'of))
	%<- (preservation' _ Eof Estep E'of) %.
%term _ 
