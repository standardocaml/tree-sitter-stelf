%sort preservation_erow {ER1} {_ erow_of ER1' TR} {_ trow_uniqueness TR} {_ erow_order ER1 ER1'} {_ step_erow ER1 ER2} {_ erow_of ER2' TR} {_ erow_order ER2 ER2'} %.
%mode preservation_erow %in %in %in %in %in %out %out %.
