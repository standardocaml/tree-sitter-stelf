%mode progress_erow %in %in %in %out %.
%term _ %pi (progress' _ (of_sub _ Eof) Eprogress) %<- (progress' _ Eof Eprogress) %.
%term _ progress' _ (of_abs _) (progresses_value value_abs) %.
%term _ progress' _ (of_tabs _) (progresses_value value_tabs) %.
%term _ 
	%pi (progress' _ (of_app E2of E1of) Eprog)
