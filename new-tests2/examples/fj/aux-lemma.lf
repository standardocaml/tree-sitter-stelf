	%pi (narrowing_exp WCT Q SB1 Q2 SB2)
	%-> (narrowing_this WCT (t_base Q) SB1 (t_base Q2) SB2) %.
%term _ 
	%pi (sub_strengthen SB2 SB3)
	%-> ({y exp} {qy typing CT y C0} {N {WCT} {C1} {C2} {SB0 subtyping CT C1 C2} narrowing_exp WCT ([x] [q typing CT x C2] qy) SB0 ([x] [q typing CT x C1] qy) s_refl} narrowing_this WCT (Q1 y qy) SB1 (Q2 y qy) (SB2 y))
	%-> (narrowing_this WCT (t_bind Q1) SB1 (t_bind Q2) SB3) %.
%worlds (b_bind) (narrowing_this WCT Q SB Q2 SB2) %.
