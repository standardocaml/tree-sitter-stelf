%%% Soundness of uniform proofs
%%% Author: Frank Pfenning
% Soundness of uniform proofs
%sort s_sound {_ solve A} {_ pf A} %.
%sort h_sound {_ assume A} {_ pf A} %.
%sort i_sound {_ A >> P} {_ %pi (pf A) %-> (pf (atom P))} %.
%name s_sound %.
%name h_sound %.
%name i_sound %.
%mode s_sound %in %out %.
%mode h_sound %in %out %.
%mode i_sound %in %out %.
%term ss_and %pi (s_sound (s_and S2 S1) (andi D2 D1)) %<- (s_sound S1 D1) %<- (s_sound S2 D2) %.
%{
ss_imp  : s_sound (s_imp S1) (impi D1)
	   <- {d:assume A} {u:pf A}
	      h_sound d u -> s_sound (S1 d) (D1 u).
}%
%term ss_true s_sound s_true truei %.
%{
ss_forall : s_sound (s_forall S1) (foralli D1)
	     <- {a:i} s_sound (S1 a) (D1 a).
}%
%term ss_atom %pi (s_sound (s_atom I2 H1) (D2 D1)) %<- (h_sound H1 D1) %<- (i_sound I2 D2) %.
%term is_andl %pi (i_sound (i_andl I1) ([u pf (A1 and A2)] D1 (andel u))) %<- (i_sound I1 D1) %.
%term is_andr %pi (i_sound (i_andr I2) ([u pf (A1 and A2)] D2 (ander u))) %<- (i_sound I2 D2) %.
%term is_imp 
	%pi (i_sound (i_imp S2 I1) ([u pf (A2 imp A1)] D1 (impe u D2)))
	%<- (i_sound I1 D1)
	%<- (s_sound S2 D2) %.
%term is_forall 
	%pi (i_sound (i_forall T I1) ([u pf (forall A1)] D1 (foralle u T)))
	%<- (i_sound I1 D1) %.
%term is_atom i_sound i_atom ([u pf (atom P)] u) %.
%worlds () (s_sound _ _) (h_sound _ _) (i_sound _ _) %.