%%% The Church-Rosser theorem for ordinary reduction
%%% Author: Frank Pfenning
%sort cr_ord {_ M <-> M'} {_ M -->* N} {_ M' -->* N} %.
% %mode +{M} +{M'} +{C:M <-> M'}
%       -{N} -{S*:M -->* N} -{S*':M' -->* N} cr_ord C S* S*'.
%mode cr_ord %in %out %out %.
%term cr_all 
	%pi (cr_ord C S* S*')
	%<- (eq6 C C')
	%<- (cr C' R* R*')
	%<- (eq4 R* S*)
	%<- (eq4 R*' S*') %.
%worlds () (cr_ord C S* S*') %.
%covers cr_ord %in %out %out %.
%terminates C (cr_ord C _ _) %.
%total C (cr_ord C _ _) %.