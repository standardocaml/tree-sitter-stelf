%{
   Formalization of the natural numbers.
   
   Author: Brian E. Aydemir (baydemir [at] cis.upenn.edu)
}%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% Syntax.
%sort nat %.
%name nat %.
%term z nat %.
%% zero.
%term s %pi nat %-> nat %.
%% successor.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% (In)Equality.
%sort nat_eq {_ nat} {_ nat} %.
%mode nat_eq %in %in %.
%sort nat_neq {_ nat} {_ nat} %.
%mode nat_neq %in %in %.
%sort nat_lt {_ nat} {_ nat} %.
%mode nat_lt %in %in %.
%term neq_eq_refl nat_eq N N %.
%term nat_neq_zs nat_neq z (s N) %.
%term nat_neq_sz nat_neq (s N) z %.
%term nat_neq_ss %pi (nat_neq (s N1) (s N2)) %<- (nat_neq N1 N2) %.
%term nat_lt_zs nat_lt z (s N) %.
%term nat_lt_ss %pi (nat_lt (s N1) (s N2)) %<- (nat_lt N1 N2) %.
%terminates {} (nat_eq _ _) %.
%terminates N (nat_neq N _) %.
%terminates N (nat_lt N _) %.