%%% val.elf
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% Values
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%term lam_v %pi tp %-> (%pi exp %-> exp) %-> val %.
%term unit_v val %.
%term pair_v %pi loc %-> loc %-> val %.