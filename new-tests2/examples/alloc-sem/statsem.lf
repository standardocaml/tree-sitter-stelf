%%% Simply Typed Lambda Calculus w/ small-step, allocation semantics
%%% Author: Matthew Fluet (June 2005)
%%% statsem.elf
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% Static Semantics
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% |-loc
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%sort |-loc {_ sttp} {_ loc} {_ tp} %.
%name |-loc %.
%mode |-loc %in %in %out %.
%term |-loc_ %pi (|-loc ST L T) %<- (sttp_lookup ST L T) %.
%terminates {} (|-loc _ _ _) %.
%worlds () (|-loc _ _ _) %.
%covers |-loc %in %in %out %.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% |-var
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%sort |-var {_ exp} {_ tp} %.
%name |-var %.
%mode |-var %in %out %.
% Church-style
%% %mode |-var +E *T. % Curry-style
%block |-var_block {T tp} [x exp] [_ |-var x T]%.
%terminates {} (|-var _ _) %.
%worlds (|-var_block) (|-var _ _) %.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% |-exp
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%sort |-exp {_ sttp} {_ exp} {_ tp} %.
%name |-exp %.
%mode |-exp %in %in %out %.
% Church-style
%% %mode |-exp +ST +E *T. % Curry-style
%term |-exp_var %pi (|-exp ST E T) %<- (|-var E T) %.
%term |-exp_loc %pi (|-exp ST (loc_e L) T) %<- (|-loc ST L T) %.
%term |-exp_lam 
	%pi (|-exp ST (lam_e Tx F) (fn_t Tx T))
	%<- ({x} %pi (|-var x Tx) %-> (|-exp ST (F x) T)) %.
%term |-exp_app %pi (|-exp ST (app_e E1 E2) T) %<- (|-exp ST E1 (fn_t Tx T)) %<- (|-exp ST E2 Tx) %.
%term |-exp_unit |-exp ST unit_e unit_t %.
%term |-exp_letunit %pi (|-exp ST (letunit_e E1 E2) T) %<- (|-exp ST E1 unit_t) %<- (|-exp ST E2 T) %.
%term |-exp_pair 
	%pi (|-exp ST (pair_e E1 E2) (pair_t T1 T2))
	%<- (|-exp ST E1 T1)
	%<- (|-exp ST E2 T2) %.
%term |-exp_letpair 
	%pi (|-exp ST (letpair_e E1 F2) T)
	%<- (|-exp ST E1 (pair_t Tx Ty))
	%<- ({x} %pi (|-var x Tx) %-> ({y} %pi (|-var y Ty) %-> (|-exp ST (F2 x y) T))) %.
%terminates E (|-exp _ E _) %.
%worlds (|-var_block) (|-exp _ _ _) %.
%covers |-exp %in %in %out %.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% |-val
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%sort |-val {_ sttp} {_ val} {_ tp} %.
%name |-val %.
%mode |-val %in %in %out %.
% Church-style
%% %mode |-val +ST +V *T. % Curry-style
%term |-val_lam 
	%pi (|-val ST (lam_v Tx F) (fn_t Tx T))
	%<- ({x} %pi (|-var x Tx) %-> (|-exp ST (F x) T)) %.
%term |-val_unit |-val ST unit_v unit_t %.
%term |-val_pair 
	%pi (|-val ST (pair_v L1 L2) (pair_t T1 T2))
	%<- (|-loc ST L1 T1)
	%<- (|-loc ST L2 T2) %.
%terminates V (|-val _ V _) %.
%worlds (|-var_block) (|-val _ _ _) %.
%covers |-val %in %in %out %.
%sort raa_|-val {_ absurd} {_ |-val ST V T} %.
%mode {%in ST sttp} {%in V val} {%in T tp} {%in Absurd absurd} {%out DValTc |-val ST V T} raa_|-val Absurd DValTc %.
%worlds () (raa_|-val _ _) %.
%total () (raa_|-val _ _) %.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% |-st
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%sort |-st {_ st} {_ sttp} %.
%name |-st %.
%mode |-st %in %out %.
% Church-style
%% %mode |-st +S +ST. % Curry-style
%term |-st_nil |-st nil_st nil_sttp %.
%term |-st_cons 
	%pi (|-st (cons_st L V S') (cons_sttp L T ST'))
	%<- (|-st S' ST')
	%<- (|-val ST' V T) %.
%terminates S (|-st S _) %.
%worlds () (|-st _ _) %.
%covers |-st %in %out %.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% |-stwf
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%sort |-stwf {_ st} {_ sttp} %.
%name |-stwf %.
%mode |-stwf %in %out %.
% Church-style
%% %mode |-stwf +S +ST. % Curry-style
%term |-stwf_ %pi (|-stwf S ST) %<- (|-st S ST) %<- (st_wf S) %<- (sttp_wf ST) %.
%terminates S (|-stwf S _) %.
%worlds () (|-stwf _ _) %.
%covers |-st %in %out %.