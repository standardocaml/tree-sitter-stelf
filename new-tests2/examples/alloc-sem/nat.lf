%%% Simply Typed Lambda Calculus w/ small-step, allocation semantics
%%% Author: Matthew Fluet (June 2005)
%%% nat.elf
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% Naturals
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%sort nat %.
%name nat %.
%term z_nat nat %.
%term s_nat %pi nat %-> nat %.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% Nat Less-than
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%sort nat_lt {_ nat} {_ nat} %.
%mode nat_lt %in %in %.
%term nat_lt_z nat_lt z_nat (s_nat _) %.
%term nat_lt_s %pi (nat_lt (s_nat N1) (s_nat N2)) %<- (nat_lt N1 N2) %.
%terminates N1 (nat_lt N1 _) %.
%worlds () (nat_lt _ _) %.