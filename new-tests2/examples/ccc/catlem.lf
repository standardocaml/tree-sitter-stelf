% Lemmas about CCC combinators
% <F,G> o H = <F o H, G o H>
%sort distp {_ pair F G @ H == pair (F @ H) (G @ H)} %.
%term distp1 distp (sym prod_u then (=pair= (ass then (=@= prod_l refl)) (ass then (=@= prod_r refl)))) %.
% app @ <cur(F) @ G, H> = F @ <G, H>
%sort appl {_ app @ pair (cur F @ G) H == F @ pair G H} %.
%term appl1 
	%pi (appl (=@= refl (=pair= (=@= refl (sym prod_l) then ass) (sym prod_r) then sym DP) then ass then =@= exp_e refl))
	%<- (distp DP) %.
% cur(F) o G = cur (F o <G o fst,snd>)
%sort distc {_ cur F @ G == cur (F @ (pair (G @ fst) snd))} %.
%term distc1 
	%pi (distc (sym exp_u then =cur= (=@= refl (=pair= (sym ass) refl) then AP)))
	%<- (appl AP) %.