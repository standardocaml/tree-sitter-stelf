% File: fol.elf
% First Order Logic Signature.
%sort i %.
%name i %.
%sort o %.
%name o %.
%term and %pi o %-> o %-> o %.
%prec %right 11 and %.
%term imp %pi o %-> o %-> o %.
%prec %right 10 imp %.
%term or %pi o %-> o %-> o %.
%prec %right 11 or %.
%term not %pi o %-> o %.
%prec %prefix 12 not %.
%term true o %.
%term false o %.
%term forall %pi (%pi i %-> o) %-> o %.
%term exists %pi (%pi i %-> o) %-> o %.