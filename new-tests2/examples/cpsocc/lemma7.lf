%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%%% Lemma 7 : Preservation of cont-validity under substitution
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%sort lemma7_2b {_ cvalC C'} {_ cvalE E} {_ cvalE ([k ccont] E (C' k))} %.
%sort lemma7_2d {_ cvalC C'} {_ cvalC C} {_ cvalC ([k ccont] C (C' k))} %.
%mode lemma7_2b %in %in %out %.
%mode lemma7_2d %in %in %out %.
%term lemma7_2b_capp 
	%pi (lemma7_2b CVC' (cval_capp CVC CVT0 CVT1) (cval_capp CVCreplC'k CVT0 CVT1))
	%<- (lemma7_2d CVC' CVC CVCreplC'k) %.
%term lemma7_2b_cret 
	%pi (lemma7_2b CVC' (cval_cret CVC CT) (cval_cret CVCreplC'k CT))
	%<- (lemma7_2d CVC' CVC CVCreplC'k) %.
%term lemma7_2d_k lemma7_2d CVC' cval_k CVC' %.
%term lemma7_2d_vlam 
	%pi (lemma7_2d CVC' (cval_vlam CVE) (cval_vlam CVEreplC'k))
	%<- ({v ctriv} {cvv cvalT v} lemma7_2b CVC' (CVE v cvv) (CVEreplC'k v cvv)) %.
%terminates (CVE CVC) (lemma7_2b _ CVE _) (lemma7_2d _ CVC _) %.