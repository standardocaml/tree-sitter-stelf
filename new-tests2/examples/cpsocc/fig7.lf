%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%%% Figure 7 : Bare, stackless CPS abstract machine 
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%sort bareR {_ croot} {_ ctriv} %.
%sort bareE {_ cexp} {_ ctriv} %.
%mode bareR %in %out %.
%mode bareE %in %out %.
% style here -fp
%{
bare_klam : bareR (klam E) A
            <- {k:ccont}
               {b:{t:ctriv}bareE (cret k t) t}
               bareE (E k) A.
}%
%term bare_klam 
	%pi (bareR (klam E) A)
	%<- ({k ccont} %pi ({T ctriv} bareE (cret k T) T) %-> (bareE (E k) A)) %.
%term bare_cret %pi (bareE (cret (vlam E) T) A) %<- (bareE (E T) A) %.
%term bare_capp %pi (bareE (capp (xlam ([x ctriv] klam (E x))) T C) A) %<- (bareE (E T C) A) %.
%name bareR %.
%name bareE %.