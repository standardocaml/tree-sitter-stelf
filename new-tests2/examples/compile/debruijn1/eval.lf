%%% Mini-ML Natural Semantics
%%% Version restricted to pure lambda-calculus
%%% Author: Frank Pfenning, based on [Michaylov & Pfenning 92]
%sort eval {_ exp} {_ exp} %.
%name eval %.
% Functions
%term ev_lam eval (lam E) (lam E) %.
%term ev_app 
	%pi (eval (app E1 E2) V)
	%<- (eval E1 (lam E1'))
	%<- (eval E2 V2)
	%<- (eval (E1' V2) V) %.