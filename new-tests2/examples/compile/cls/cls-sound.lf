%%% Mapping CLS computations to evaluations.
%%% This expresses the soundness proof for the CLS machine.
%%% Author: Frank Pfenning, based on [Hannan & Pfenning 92]
%%% The postfix ordering for computations.
%%% This is ordering is well-founded.
%sort < {_ st KS1 P1 S1 =>* (st KS P S)} {_ st KS2 P2 S2 =>* (st KS P S)} %.
%prec %none 8 < %.
%mode < %in %in %.
%term sub_imm C < R ~ C %.
%term sub_med %pi (C < C') %-> (C < R ~ C') %.
%{
Lemma: The postfix relation on computations is transitive:
  For every  R1 :: C1 < C2  and  R2 :: C2 < C3
  there exists an  R3 :: C1 < C3.

Proof: By induction on the structure of R2.
}%
%sort trans* {_ C1 < C2} {_ C2 < C3} {_ C1 < C3} %.
%mode trans* %in %in %out %.
%term trans*_imm trans* R1 sub_imm (sub_med R1) %.
%term trans*_med %pi (trans* R1 (sub_med R2) (sub_med R3)) %<- (trans* R1 R2 R3) %.
%{
Splitting Lemma:
  If C :: (st (KS ;; K) (ev F & P) S) =>* (st (emptys) (done) (empty ; W'))
  then there exists a value W, an evaluation
    D :: feval K F W
  and a computation
    C' :: (st KS P (S ; W)) =>* (st (emptys) (done) (empty ; W'))
  such that C' < C.

Proof: By complete induction on C.
}%
%sort spl {C st (KS ;; K) (ev F & P) S =>* (st emptys done (empty ; W'))} {_ feval K F W} {C' st KS P (S ; W) =>* (st emptys done (empty ; W'))} {_ C' < C} %.
%mode spl %in %out %out %out %.
% C = id  is impossible, since  (ev F & P)  is different from  (done).
% Variables
%term spl_1 spl (c_1 ~ C1) fev_1 C1 sub_imm %.
%term spl_^ %pi (spl (c_^ ~ C1) (fev_^ D1) C2 (sub_med C2<C1)) %<- (spl C1 D1 C2 C2<C1) %.
%term spl_1+ %pi (spl (c_1+ ~ C1) (fev_1+ D1) C2 (sub_med C2<C1)) %<- (spl C1 D1 C2 C2<C1) %.
%term spl_^+ %pi (spl (c_^+ ~ C1) (fev_^+ D1) C2 (sub_med C2<C1)) %<- (spl C1 D1 C2 C2<C1) %.
% Natural Numbers
%term spl_z spl (c_z ~ C1) fev_z C1 sub_imm %.
%term spl_s 
	%pi (spl (c_s ~ C1) (fev_s D1) C2' (sub_med C2'<C1))
	%<- (spl C1 D1 (c_add1 ~ C2') C2<C1)
	%<- (trans* sub_imm C2<C1 C2'<C1) %.
%term spl_case_z 
	%pi (spl (c_case ~ C1) (fev_case_z D2 D1) C3 (sub_med C3<C1))
	%<- (spl C1 D1 (c_branch_z ~ C2') C2<C1)
	%<- (spl C2' D2 C3 C3<C2')
	%<- (trans* sub_imm C2<C1 C2'<C1)
	%<- (trans* C3<C2' C2'<C1 C3<C1) %.
%term spl_case_s 
	%pi (spl (c_case ~ C1) (fev_case_s D3 D1) C3 (sub_med C3<C1))
	%<- (spl C1 D1 (c_branch_s ~ C2') C2<C1)
	%<- (spl C2' D3 C3 C3<C2')
	%<- (trans* sub_imm C2<C1 C2'<C1)
	%<- (trans* C3<C2' C2'<C1 C3<C1) %.
% Pairs
%term spl_pair 
	%pi (spl (c_pair ~ C1) (fev_pair D2 D1) C3' (sub_med C3'<C1))
	%<- (spl C1 D1 C2 C2<C1)
	%<- (spl C2 D2 (c_mkpair ~ C3') C3<C2)
	%<- (trans* sub_imm C3<C2 C3'<C2)
	%<- (trans* C3'<C2 C2<C1 C3'<C1) %.
%term spl_fst 
	%pi (spl (c_fst ~ C1) (fev_fst D1) C2' (sub_med C2'<C1))
	%<- (spl C1 D1 (c_getfst ~ C2') C2<C1)
	%<- (trans* sub_imm C2<C1 C2'<C1) %.
%term spl_snd 
	%pi (spl (c_snd ~ C1) (fev_snd D1) C2' (sub_med C2'<C1))
	%<- (spl C1 D1 (c_getsnd ~ C2') C2<C1)
	%<- (trans* sub_imm C2<C1 C2'<C1) %.
% Functions
%term spl_lam spl (c_lam ~ C1) fev_lam C1 sub_imm %.
%term spl_app 
	%pi (spl (c_app ~ C1) (fev_app D3 D2 D1) C4 (sub_med C4<C1))
	%<- (spl C1 D1 C2 C2<C1)
	%<- (spl C2 D2 (c_apply ~ C3') C3<C2)
	%<- (spl C3' D3 C4 C4<C3')
	%<- (trans* C3<C2 C2<C1 C3<C1)
	%<- (trans* sub_imm C3<C1 C3'<C1)
	%<- (trans* C4<C3' C3'<C1 C4<C1) %.
% Definitions
%term spl_letv 
	%pi (spl (c_letv ~ C1) (fev_letv D2 D1) C3 (sub_med C3<C1))
	%<- (spl C1 D1 (c_bind ~ C2') C2<C1)
	%<- (spl C2' D2 C3 C3<C2')
	%<- (trans* sub_imm C2<C1 C2'<C1)
	%<- (trans* C3<C2' C2'<C1 C3<C1) %.
%term spl_letn %pi (spl (c_letn ~ C2) (fev_letn D2) C3 (sub_med C3<C2)) %<- (spl C2 D2 C3 C3<C2) %.
% Recursion
%term spl_fix %pi (spl (c_fix ~ C1) (fev_fix D1) C2 (sub_med C2<C1)) %<- (spl C1 D1 C2 C2<C1) %.
%{
Soundness Theorem: For every complete computation
  E :: ceval K F W
there exists an evaluation
  D :: feval K F W

Proof: By the splitting lemma for computations.
}%
%sort cls_sound {_ ceval K F W} {_ feval K F W} %.
%mode cls_sound %in %out %.
%term clss %pi (cls_sound (run C) D) %<- (spl C D id Id<C) %.