%%% The Mini-ML Language
%%% Version distinguishing expressions and values
%%% Author: Frank Pfenning
%sort exp %.
%name exp %.
%sort val %.
%name val %.
%term z exp %.
%term s %pi exp %-> exp %.
%term case %pi exp %-> exp %-> (%pi val %-> exp) %-> exp %.
%term pair %pi exp %-> exp %-> exp %.
%term fst %pi exp %-> exp %.
%term snd %pi exp %-> exp %.
%term lam %pi (%pi val %-> exp) %-> exp %.
%term app %pi exp %-> exp %-> exp %.
%term letv %pi exp %-> (%pi val %-> exp) %-> exp %.
%term letn %pi exp %-> (%pi exp %-> exp) %-> exp %.
%term fix %pi (%pi exp %-> exp) %-> exp %.
%term vl %pi val %-> exp %.
%term z* val %.
%term s* %pi val %-> val %.
%term pair* %pi val %-> val %-> val %.
%term lam* %pi (%pi val %-> exp) %-> val %.