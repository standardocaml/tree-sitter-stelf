%query 1 _ _ cmp (lam ([x] pair (snd x) (fst x))) ([x] vl+ x) E %.
%query 1 _ _ cmp (app (lam ([x] pair (snd x) (fst x))) (pair z (s z))) ([x] vl+ x) E %.
%query 1 _ _ ceval (vl+ (lam+ ([x' cval] [k %pi cval %-> cexp] snd+ x' ([x1' cval] fst+ x' ([x2' cval] k (pair+ x1' x2')))))) V %.
%query 1 _ _ ceval (app+ (lam+ ([x' cval] [k %pi cval %-> cexp] snd+ x' ([x1' cval] fst+ x' ([x2' cval] k (pair+ x1' x2'))))) (pair+ z+ (s+ z+)) ([x cval] vl+ x)) V %.